{
  "name": "ca2-order-inventory-tests",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:services": "npm --prefix services/product-service install && npm --prefix services/order-service install",
    "test:functional:coverage": "c8 --reporter=lcov --reporter=text --report-dir coverage/functional --include \"services/frontend/**/*.js\" node test/functional/run-functional-tests.js",
    "test:api:coverage": "c8 --reporter=lcov --reporter=text --report-dir coverage/api --include \"services/product-service/**/*.js\" --include \"services/order-service/**/*.js\" --exclude \"**/server.js\" node test/api/run-api-coverage-tests.js",
    "test:api:deployed": "node test/api/run-api-tests.js",
    "test:integration:coverage": "c8 --reporter=lcov --reporter=text --report-dir coverage/integration --include \"services/**/*.js\" --exclude \"**/server.js\" node test/integration/run-integration-tests.js"
  },
  "devDependencies": {
    "c8": "^10.1.3"
  }
}
